# Copia este archivo a .env.local y rellena los valores.

# --- Gemini ---
# En local (dev) la app puede llamar a Gemini directo con esta key.
# En producción se usa vía la función serverless de Vercel (api/gemini) para
# no exponerla; ahí se define como variable de entorno en Vercel.
GEMINI_API_KEY=

# --- Firebase Web config ---
# Firebase Console → Project settings (engrane) → General → Your apps →
# (Web app) SDK setup and configuration → Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
